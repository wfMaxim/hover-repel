{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "ES2020"],

    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    "outDir": "dist",
    "rootDir": "src",

    "skipLibCheck": true,
    "noEmitOnError": true,
    "isolatedModules": true,

    "ignoreDeprecations": "6.0"
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}