{
  "name": "hover-repel",
  "version": "0.1.2",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js",
      "require": "./dist/vue/index.cjs"
    },
    "./browser": "./dist/browser.global.js",
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "./dist/style.css"
  ],
  "scripts": {
    "build": "tsup && copyfiles -u 1 src/style.css dist"
  },
  "peerDependencies": {
    "vue": "^3"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "copyfiles": "latest",
    "tsup": "latest",
    "typescript": "^5.0.0",
    "vue": "^3.5.0"
  }
}
